# Centro inicial del mapa (lat,lng)
EXPO_PUBLIC_MAP_CENTER=32.5149,-117.0382

# Google Maps — Places API (New) para búsqueda de lugares
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenRouteService — solo rutas a pie (https://openrouteservice.org/dev/)
EXPO_PUBLIC_ORS_API_KEY=your_openrouteservice_api_key_here

# Gemini — describe fotos al rerutear (multimodal, base64 en inline_data)
# Crear en https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
