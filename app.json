{
  "expo": {
    "name": "Hackfox2026",
    "slug": "hackfox2026",
    "scheme": "hackfox2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Permite tomar fotos para reportar obstáculos al rerutear."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permite ubicarte para calcular rutas y mostrar tu posición.",
          "locationAlwaysAndWhenInUsePermission": "Permite seguir tu ruta y disparar instrucciones aunque la app esté en segundo plano."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Permite grabar audio para buscar rutas accesibles por voz."
        }
      ],
      "expo-router"
    ],
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ],
      "package": "com.jpdessens.hackfox2026"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a412f1c3-6982-4dd7-a2bb-c11ba577953e"
      }
    },
    "owner": "jesse05",
    "updates": {
      "url": "https://u.expo.dev/a412f1c3-6982-4dd7-a2bb-c11ba577953e"
    },
    "ios": {}
  }
}
