{
  "expo": {
    "name": "Hackfox2026",
    "slug": "hackfox2026",
    "scheme": "hackfox2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Permite tomar fotos para reportar obstáculos al rerutear."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permite ubicarte para calcular rutas y mostrar tu posición.",
          "locationAlwaysAndWhenInUsePermission": "Permite seguir tu ruta y disparar instrucciones aunque la app esté en segundo plano."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Permite grabar audio para buscar rutas accesibles por voz."
        }
      ],
      "expo-router"
    ],
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ],
      "package": "com.jpdessens.hackfox2026"
    },
    "extra": {
      "eas": {
        "projectId": "f230e11c-7c77-4d9f-a6f0-039891ae1619"
      }
    },
    "owner": "jpdessens"
  }
}
